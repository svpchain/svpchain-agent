# Build output
/build/

# macOS iconset staging directory (generated by scripts/build-macos-icon.sh)
/build/AppIcon.iconset/

# Editor / system cruft
.DS_Store
*.swp
.idea/

# Wails frontend build artifacts and generated bindings
/cmd/svpchain-gui/frontend/node_modules/
/cmd/svpchain-gui/frontend/wailsjs/
# Only ignore the compiled output; keep Wails source assets (build/appicon.png, build/darwin/…).
/cmd/svpchain-gui/build/

# Keep an embeddable placeholder so `go build` works without the frontend toolchain;
# `wails build` / `vite build` regenerate the real assets.
/cmd/svpchain-gui/frontend/dist/*
!/cmd/svpchain-gui/frontend/dist/.gitkeep
/svpchain-gui
